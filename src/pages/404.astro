---
import Base from '../layouts/Base.astro';
---

<Base title="Page Not Found | FOSSBilling extensions">
  <div class="xl:mx-48 p-6 sm:p-10 text-center">
    <h1 class="text-3xl font-bold tracking-tight mb-4">404 - Page Not Found</h1>
    <p class="text-muted-foreground mb-6">
      The page you're looking for doesn't exist.
    </p>
    <a href="/" class="btn btn-primary">Back to Extensions</a>
  </div>
</Base>
