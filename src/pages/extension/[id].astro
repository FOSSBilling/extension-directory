---
import Base from '@/layouts/Base.astro';
import ExtensionHeader from '@/components/ExtensionHeader.astro';
import DetailsCard from '@/components/DetailsCard.astro';
import ReleasesCard from '@/components/ReleasesCard.astro';
import Overview from '@/components/Overview.astro';
import ReleasesTable from '@/components/ReleasesTable.astro';
import { extensionData } from '@/data/extensions';

const { id } = Astro.params;

if (!id) {
  return Astro.redirect('/404');
}

const ext = extensionData.find(
  (data) => data.id.toLowerCase() === id.toString().toLowerCase(),
);

if (!ext) {
  return Astro.redirect('/404');
}

export function getStaticPaths() {
  return extensionData.map((ext) => ({
    params: { id: ext.id },
    props: { ext },
  }));
}
---

<Base title={`${ext.name} | FOSSBilling Extensions`}>
  <ExtensionHeader ext={ext} />

  <div data-tabs class="mt-6" role="tablist" aria-label="Extension tabs">
    <button
      role="tab"
      data-tab="overview"
      class="tab-btn px-3 py-1.5 text-sm font-medium rounded-sm text-muted-foreground hover:bg-muted hover:text-foreground transition-colors bg-background text-foreground shadow-sm"
      aria-selected="true"
      aria-controls="overview-panel"
    >
      Overview
    </button>
    <button
      role="tab"
      data-tab="release-history"
      class="tab-btn px-3 py-1.5 text-sm font-medium rounded-sm text-muted-foreground hover:bg-muted hover:text-foreground transition-colors"
      aria-selected="false"
      aria-controls="release-history-panel"
    >
      Release history
    </button>
  </div>

  <div class="grid gap-6 lg:grid-cols-6 mt-6">
    <div class="lg:col-span-4">
      <article class="card h-full">
        <div class="card-body h-full p-0">
          <div
            role="tabpanel"
            id="overview-panel"
            data-tab-panel="overview"
            class="p-6"
            aria-labelledby="overview-tab"
          >
            <Overview ext={ext} />
          </div>
          <div
            role="tabpanel"
            id="release-history-panel"
            data-tab-panel="release-history"
            class="p-6 hidden"
            aria-labelledby="release-history-tab"
          >
            <ReleasesTable ext={ext} />
          </div>
        </div>
      </div>

      <div class="lg:col-span-2 space-y-6">
        <DetailsCard ext={ext} />
        <ReleasesCard ext={ext} />
      </div>
  </div>
</Base>