---
import type { Extension } from '@/types';
import { getLatestRelease, sortReleasesDescending } from '@/types';
import { formatDistanceToNow } from 'date-fns';
import { enUS } from 'date-fns/locale';
import { Download } from '@lucide/astro';

interface Props {
  ext?: Extension;
}

const { ext } = Astro.props;

const latest = ext ? getLatestRelease(ext) : undefined;
const latestThree = ext ? sortReleasesDescending(ext.releases).slice(0, 3) : [];
---

<article class="card">
  {
    latest ? (
      <>
        <header>
          <div class="flex items-center justify-between">
            <h2>Latest Release</h2>
            <a
              href={latest.download_url}
              target="_blank"
              rel="noopener noreferrer"
              class="badge gap-1 cursor-pointer"
            >
              <Download class="w-4 h-4" />v{latest.tag}
            </a>
          </div>
          <p class="text-sm text-muted-foreground mt-1">
            <time datetime={latest.date}>
              {formatDistanceToNow(new Date(latest.date), {
                locale: enUS,
                addSuffix: true,
              })}
            </time>
          </p>
        </header>
        <section>
          <ul class="space-y-2">
            {latestThree.map((release) => (
              <li
                id={`recent-${release.tag}`}
                class="flex justify-between text-sm"
              >
                <span>v{release.tag}</span>
                <span class="text-muted-foreground">
                  <time datetime={release.date}>
                    {formatDistanceToNow(new Date(release.date), {
                      locale: enUS,
                      addSuffix: true,
                    })}
                  </time>
                </span>
              </li>
            ))}
          </ul>
        </section>
      </>
    ) : (
      <header>
        <h2>Latest Release</h2>
      </header>
    )
  }
</article>
