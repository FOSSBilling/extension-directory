---
import type { Extension } from '@/types';
import { getLatestRelease, repositoryURL } from '@/types';
import { CircleCheck, GitBranch, Scale, User } from '@lucide/astro';

interface Props {
  ext: Extension;
}

const { ext } = Astro.props;
const latest = getLatestRelease(ext);

type DetailsItem = {
  name: string;
  icon: typeof User;
  color: 'amber' | 'green' | 'blue' | 'fuchsia';
  text: string;
  link?: string;
};

const iconBgClasses: Record<'amber' | 'green' | 'blue' | 'fuchsia', string> = {
  amber: 'bg-amber-100 text-amber-700',
  green: 'bg-green-100 text-green-700',
  blue: 'bg-blue-100 text-blue-700',
  fuchsia: 'bg-fuchsia-100 text-fuchsia-700',
};

const badgeColorClasses: Record<
  'amber' | 'green' | 'blue' | 'fuchsia',
  string
> = {
  amber: 'bg-amber-100 text-amber-700',
  green: 'bg-green-100 text-green-700',
  blue: 'bg-blue-100 text-blue-700',
  fuchsia: 'bg-fuchsia-100 text-fuchsia-700',
};

const details: DetailsItem[] = [
  {
    name: 'Publisher',
    icon: User,
    color: 'amber',
    text: ext.author.id,
    link: ext.website,
  },
  {
    name: 'Compatible with',
    icon: CircleCheck,
    color: 'green',
    text: latest
      ? `FOSSBilling v${latest.min_fossbilling_version} and later`
      : 'Unknown version',
  },
  {
    name: 'License',
    icon: Scale,
    color: 'blue',
    text: ext.license.name,
    link: ext.license.URL,
  },
  {
    name: 'Source code',
    icon: GitBranch,
    color: 'fuchsia',
    text: ext.source.repo,
    link: repositoryURL(ext.source),
  },
];
---

<article class="card">
  <header>
    <h2>Extension Details</h2>
  </header>
  <section>
    <ul class="space-y-4">
      {
        details.map((detail) => (
          <li
            id={`detail-${detail.name.toLowerCase().replace(/\s+/g, '-')}`}
            class="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3"
          >
            <div class="flex items-center space-x-3">
              <span class={`p-2 rounded-lg ${iconBgClasses[detail.color]}`}>
                <detail.icon class="w-4 h-4" aria-hidden="true" />
              </span>
              <div>
                <p class="font-medium text-sm">{detail.name}</p>
              </div>
            </div>
            <div class="flex items-center space-x-2">
              {detail.link ? (
                <a
                  href={detail.link}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="btn btn-outline btn-sm"
                >
                  {detail.text}
                </a>
              ) : (
                <span
                  class={`badge text-xs ${badgeColorClasses[detail.color]}`}
                >
                  {detail.text}
                </span>
              )}
            </div>
          </li>
        ))
      }
    </ul>
  </section>
</article>
